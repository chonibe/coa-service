# Shopify OAuth Configuration
SHOPIFY_CLIENT_ID=your_shopify_client_id
SHOPIFY_CLIENT_SECRET=your_shopify_client_secret
SHOPIFY_SHOP=your-store.myshopify.com
# Optional: Shopify "API secret key" from app credentials; used as webhook HMAC secret if SHOPIFY_WEBHOOK_SECRET is not set
# SHOPIFY_API_SECRET=your_shopify_api_secret
# SHOPIFY_WEBHOOK_SECRET=your_webhook_secret

# WhatsApp Business API (Meta Cloud API) - Required for webhook signature verification
# WHATSAPP_WEBHOOK_SECRET=your_whatsapp_app_secret

# CRM webhook (Attio) - Required for inbound webhook signature verification
# CRM_WEBHOOK_SECRET=your_attio_webhook_secret

# Shopify Storefront API (required for shop/experience product data)
NEXT_PUBLIC_SHOPIFY_STOREFRONT_TOKEN=your_storefront_api_token
# Optional: private Storefront token for unlisted products (server-only). If Admin returns handles but Storefront returns 0 products, set this.
# SHOPIFY_STOREFRONT_PRIVATE_TOKEN=your_private_storefront_token
SHOPIFY_REDIRECT_URI=https://streetcollector.vercel.app/apps/coa-manager/auth/callback
SHOPIFY_SCOPES=read_customers,read_orders,read_products,write_apps

# Mapbox Configuration (for maps and geocoding in artwork/location blocks only)
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_public_token

# Google Maps/Places API (required for checkout address autocomplete; enables ZIP/postal extraction)
# Use NEXT_PUBLIC_GOOGLE_MAPS_API_KEY or NEXT_PUBLIC_GOOGLE_PLACES_API_KEY for client-side
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
# NEXT_PUBLIC_GOOGLE_PLACES_API_KEY=your_google_places_api_key

# Google Analytics (GA4)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-V9LJ3T3LK8

# PostHog (session replay, product analytics, heatmaps)
NEXT_PUBLIC_POSTHOG_KEY=phc_your_project_api_key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# Filter out internal users: comma-separated emails and/or distinct_ids (Supabase user IDs)
# Also visit your site with ?posthog_filter_me=1 once to filter this device (anonymous sessions)
# NEXT_PUBLIC_POSTHOG_FILTER_EMAILS=you@example.com,dev@example.com
# NEXT_PUBLIC_POSTHOG_FILTER_DISTINCT_IDS=uuid-from-posthog-person-page
# PostHog Insights Setup (for Vercel deployment automation)
# Personal API key (phx_...) - RECOMMENDED: https://app.posthog.com/settings/user-api-keys → create new key
# POSTHOG_PERSONAL_API_KEY=phx_your_personal_api_key
# Project API key (phc_...) - Fallback: https://app.posthog.com/settings/project → "Project API Key"
# POSTHOG_API_KEY=phc_your_project_api_key
# Project ID from https://app.posthog.com/settings/project
# POSTHOG_PROJECT_ID=your_project_id
# Enable/disable automatic insights setup during Vercel production builds (default: enabled if API key set)
# POSTHOG_SETUP_ENABLED=true

# Meta Conversions API (server-side events)
# Access token from Meta Events Manager (Dataset Quality API token works)
META_DATASET_API_KEY=your_meta_dataset_api_key
# Use your Dataset ID (or Pixel ID) from Events Manager
META_DATASET_ID=your_meta_dataset_or_pixel_id
# Meta Pixel ID for browser events + CAPI dedup
NEXT_PUBLIC_META_PIXEL_ID=your_meta_pixel_id
# Optional: send events into Meta Test Events tool
# META_TEST_EVENT_CODE=TEST12345

# Optional: auto-fill artist Instagram grids via Instagram Graph API [Business Discovery]
# (only when custom.instagram_showcase is empty; target must be Business/Creator — see docs/features/street-collector/artist-profile-content-spec.md §7)
# Caller IG user id: INSTAGRAM_BUSINESS_DISCOVERY_IG_USER_ID or INSTAGRAM_BUSINESS_ID (Vercel often has the latter)
# Token: INSTAGRAM_ACCESS_TOKEN or INSTAGRAM_MANUAL_ACCESS_TOKEN
# INSTAGRAM_BUSINESS_DISCOVERY_IG_USER_ID=
# INSTAGRAM_BUSINESS_ID=
# INSTAGRAM_ACCESS_TOKEN=
# INSTAGRAM_MANUAL_ACCESS_TOKEN=

# Optional: headless skill evolution (npm run skill-evolution:run). Prefer ~/.config/coa-service/skill-evolution.env for LaunchAgent; see scripts/skill-evolution.env.example.
# ANTHROPIC_API_KEY=

# Shop Footer Pages
CONTACT_EMAIL=info@thestreetlamp.com
NEXT_PUBLIC_CONTACT_EMAIL=info@thestreetlamp.com
# Optional: “country not listed” checkout mailto; defaults to NEXT_PUBLIC_CONTACT_EMAIL then collector support
# NEXT_PUBLIC_ORDER_OUTREACH_EMAIL=support@thestreetcollector.com
NEXT_PUBLIC_COLLABS_SIGNUP_URL=https://collabs.shopify.com/creator
NEXT_PUBLIC_COLLABS_LOGIN_URL=https://collabs.shopify.com/creator
# NEXT_PUBLIC_CAREERS_URL=https://your-job-board-url.com

# ChinaDivision + daily Slack warehouse summary (cron: /api/cron/warehouse-daily-slack)
# CHINADIVISION_API_KEY=your_chinadivision_api_key
# CRON_SECRET=your_random_secret_for_vercel_cron
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# Optional: lookback days for orders-info (default 90, max 365)
# WAREHOUSE_SLACK_SUMMARY_DAYS=90
# Optional: max open orders to list + fetch tracking for (default 50, max 100)
# WAREHOUSE_SLACK_OPEN_ORDER_LIMIT=50

# Shop experience: optional Spline **embed** URL for the small lamp preview tile in the bottom collection strip (see ArtworkCarouselBar)
# NEXT_PUBLIC_EXPERIENCE_CAROUSEL_MINI_SPLINE_EMBED_URL=https://my.spline.design/…/embed
